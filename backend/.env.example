PORT=8789
TOSS_API_BASE=https://apps-in-toss-api.toss.im
TOSS_TEMPLATE_SET_CODE=pill-time-templateSetCode
TZ=Asia/Seoul

# 앱인토스 콘솔 → mTLS 인증서 탭에서 발급 (PEM 전체를 한 줄 또는 파일 경로)
TOSS_MTLS_CERT=
TOSS_MTLS_KEY=

# 또는 파일 경로 (로컬)
# TOSS_MTLS_CERT_PATH=./certs/client-cert.pem
# TOSS_MTLS_KEY_PATH=./certs/client-key.pem
