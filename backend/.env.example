PORT=8789
TOSS_API_BASE=https://apps-in-toss-api.toss.im
TOSS_TEMPLATE_SET_CODE=pill-time-templateSetCode
TOSS_DEPLOYMENT_ID=019ecf5d-3a1c-7d11-a78a-53eade7db6bd
# auto = deploymentId 있으면 테스트 발송 API, 없으면 본발송
TOSS_PUSH_MODE=live
TZ=Asia/Seoul

# mTLS — 로컬은 ../mTLS/약먹을시간_*.crt·key 자동 로드 (비워 둬도 됨)
# Render 는 npm run mtls:print 로 출력한 값을 환경 변수에 넣기
TOSS_MTLS_CERT=
TOSS_MTLS_KEY=

# 또는 파일 경로
# TOSS_MTLS_CERT_PATH=../mTLS/약먹을시간_public.crt
# TOSS_MTLS_KEY_PATH=../mTLS/약먹을시간_private.key
